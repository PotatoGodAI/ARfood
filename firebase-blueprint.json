{
  "entities": {
    "Model": {
      "title": "3D Model",
      "description": "A 3D food model metadata",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "url": { "type": "string" },
        "type": { "type": "string", "enum": ["file", "link"] },
        "size": { "type": "number" },
        "restaurant": { "type": "string" },
        "createdAt": { "type": "number" },
        "userId": { "type": "string" },
        "storagePath": { "type": "string" },
        "originalName": { "type": "string" }
      },
      "required": ["name", "url", "type", "createdAt", "userId"]
    }
  },
  "firestore": {
    "/models/{modelId}": {
      "schema": "Model",
      "description": "Collection of 3D models"
    }
  }
}
